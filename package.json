{
  "name": "dragnet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Real-time fraud-ring buster — Neo4j GDS + RocketRide Cloud + Butterbase (+ Cognee)",
  "scripts": {
    "seed": "tsx src/data/generate.ts",
    "seed:json": "tsx src/data/generate.ts -- --json-only",
    "server": "tsx watch src/server.ts",
    "web": "npm --prefix web run dev",
    "dev": "npm run seed:json && concurrently -n server,web -c cyan,magenta \"npm run server\" \"npm run web\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "neo4j-driver": "^5.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
