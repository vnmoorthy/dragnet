# ---- Copy to .env and fill in. Leave blank to run in bulletproof DEMO MODE. ----

# Neo4j Aura (mandatory for the live graph story)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# RocketRide Cloud (mandatory: deployed pipeline endpoint from cloud.rocketride.ai)
ROCKETRIDE_ENDPOINT=
ROCKETRIDE_API_KEY=

# Butterbase backend (mandatory: db + auth + payment). Get key at dashboard.butterbase.ai
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_API_KEY=
BUTTERBASE_APP_ID=          # required for live mode (from dashboard.butterbase.ai)
BUTTERBASE_PRO_PLAN_ID=pro

# Cognee sidecar (BONUS). Only if cognee_service.py is running.
COGNEE_URL=

PORT=8787
